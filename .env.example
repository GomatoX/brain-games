# ─── Core ────────────────────────────────────────────────
AUTH_SECRET=          # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# ─── Database ───────────────────────────────────────────
# Use ONE of the following (DATABASE_URL takes priority):
# DATABASE_URL=postgres://user:pass@host:5432/brain_games
DATABASE_PATH=./data/brain.db

# ─── AI (optional) ──────────────────────────────────────
GOOGLE_AI_API_KEY=

# ─── Branding (runtime, no rebuild needed) ──────────────
# PLATFORM_MODE=whitelabel
# PLATFORM_NAME=My Platform
# PLATFORM_ACCENT=#c25e40
# PLATFORM_LOGO=
# HIDE_LANDING=true
# HIDE_REGISTER=true

# ─── Default User (auto-created on startup) ────────────
# DEFAULT_USER_EMAIL=admin@example.com
# DEFAULT_USER_PASSWORD=changeme123
